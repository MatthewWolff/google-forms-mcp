{
  "name": "@matthewwolff/google-forms-mcp",
  "version": "1.0.2",
  "description": "Comprehensive MCP server for the Google Forms API — full coverage of form creation, management, responses, and built-in analytics",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Matthew Wolff",
    "url": "https://github.com/MatthewWolff"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MatthewWolff/google-forms-mcp"
  },
  "homepage": "https://github.com/MatthewWolff/google-forms-mcp#readme",
  "bugs": {
    "url": "https://github.com/MatthewWolff/google-forms-mcp/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "google-forms",
    "google-forms-api",
    "claude",
    "ai",
    "forms",
    "survey",
    "analytics"
  ],
  "mcpName": "io.github.matthewwolff/google-forms",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "google-forms-mcp": "dist/index.js",
    "google-forms-mcp-auth": "dist/get-refresh-token.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/index.js dist/get-refresh-token.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "googleapis": "^148.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "dotenv": "^17.4.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
